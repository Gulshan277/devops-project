terraform {
  required_providers {
    docker = {
      source = "kreuzwerker/docker"
    }
  }
}

resource "docker_image" "mysql" {
  name = "mysql:8"
}

resource "docker_container" "mysql" {
  name  = "mysql"
  image = docker_image.mysql.name

  env = [
    "MYSQL_ROOT_PASSWORD=root",
    "MYSQL_DATABASE=devops"
  ]

  ports {
    internal = 3306
    external = 3306
  }

  networks_advanced {
    name = var.network_name
  }
}
